/* styles/base.css — vars, reset, body, view system, typography, buttons, qr, sync, lottie, buffer, summary, mode themes, qa-game */
/* Vanilla CSS for Social Anchor MVP
  Responsive, modern, glassmorphism UI logic 
*/

:root {
  --bg-color-dark: #0f172a;
  --bg-color-flow: #064e3b;
  --bg-color-danger: #7f1d1d;
  --text-primary: #f8fafc;
  --text-secondary: #94a3b8;
  --accent-color: #3b82f6;
  --accent-hover: #2563eb;
  --font-family: 'Inter', system-ui, -apple-system, sans-serif;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  user-select: none;
}

body {
  font-family: var(--font-family);
  background-color: var(--bg-color-dark);
  color: var(--text-primary);
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  margin: 0;
  overflow-y: auto; 
  transition: background-color 1s ease;
}

/* Base Body Modes */
body.mode-flow {
  background-color: var(--bg-color-flow);
}
body.mode-danger {
  background-color: var(--bg-color-danger);
}

#app-container {
  width: 100%;
  max-width: 480px;
  min-height: 150vh;
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 24px;
}

/* View Manage System */
.view {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  flex-grow: 1;
  text-align: center;
  animation: fadeIn 0.4s ease forwards;
}

.view.active {
  display: flex;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Typography */
h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 8px; }
h2 { font-size: 1.8rem; font-weight: 700; margin-bottom: 12px; }
p { font-size: 1rem; color: var(--text-secondary); margin-bottom: 24px; }

/* Buttons */
.btn {
  width: 100%;
  padding: 16px;
  border-radius: 12px;
  border: none;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.1s, opacity 0.2s;
  margin-bottom: 16px;
}

.btn:active {
  transform: scale(0.97);
}

.btn.primary {
  background-color: var(--accent-color);
  color: white;
  box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
}

.btn.secondary {
  background-color: transparent;
  color: white;
  border: 1px solid var(--text-secondary);
}

.btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* QR Code Section */
.qr-container {
  background: white;
  padding: 16px;
  border-radius: 16px;
  margin: 24px 0;
  box-shadow: 0 10px 25px rgba(0,0,0,0.5);
}

.qr-container img {
  width: 200px;
  height: 200px;
}

/* Sync Ritual Component */
.sync-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
  margin-top: 40px;
  width: 100%;
}

.progress-bar-bg {
  width: 80%;
  height: 24px;
  background-color: rgba(255,255,255,0.1);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: inset 0 2px 4px rgba(0,0,0,0.3);
}

.progress-bar-fill {
  width: 0%;
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #10b981);
  border-radius: 12px;
  transition: width 0.1s linear;
}

.btn-circular {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  border: none;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: white;
  font-size: 1.2rem;
  font-weight: bold;
  box-shadow: 0 10px 25px rgba(59, 130, 246, 0.5);
  cursor: pointer;
  transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.btn-circular:active {
  transform: scale(0.85);
  box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
}

/* Flow Lottie Container */
.lottie-container {
  width: 300px;
  height: 300px;
  margin: 40px 0;
}

/* Buffer View Overlay */
.overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(10px);
  z-index: 100;
}

.buffer-content {
  text-align: center;
}

.timer {
  font-size: 6rem;
  color: #ef4444;
  font-variant-numeric: tabular-nums;
  margin: 20px 0;
  text-shadow: 0 0 20px rgba(239, 68, 68, 0.5);
}

.buffer-hint {
  font-weight: bold;
  color: #fca5a5;
}

.summary-card {
  background: rgba(255,255,255,0.05);
  padding: 32px;
  border-radius: 24px;
  width: 100%;
  margin-bottom: 32px;
  border: 1px solid rgba(255,255,255,0.1);
}

/* =========================================
   新增：模式切換與問答遊戲 (Q&A Game) 樣式
========================================= */

/* 房主模式選擇控制區塊 */
.mode-controls {
  margin: 24px 0;
  padding: 20px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  width: 100%;
}

.mode-controls h3 {
  margin-top: 0;
  margin-bottom: 16px;
  font-size: 1.1rem;
  color: var(--text-primary);
}

.mode-btns {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 問答遊戲卡片區塊 */
.qa-card {
  background: rgba(255, 255, 255, 0.05);
  padding: 24px;
  border-radius: 16px;
  margin: 24px 0;
  width: 100%;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* 問答遊戲選項按鈕 */
.qa-option-btn {
  padding: 16px 20px;
  border-radius: 12px;
  border: 1px solid var(--text-secondary);
  background: transparent;
  color: var(--text-primary);
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  text-align: center;
  transition: all 0.2s;
}

.qa-option-btn:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.1);
  transform: translateY(-2px);
  border-color: var(--text-primary);
}

.qa-option-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  border-color: rgba(255, 255, 255, 0.1);
  transform: none;
}

#qa-status {
  font-weight: bold;
  margin-top: 16px;
  color: #10b981; 
  min-height: 24px;
}

.btn.secondary.active-mode {
  background-color: rgba(16, 185, 129, 0.2);
  border-color: #34d399;
  color: #a7f3d0;
  box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
  transform: scale(0.98);
}
/* 聚會背景主題色同步 */
body.mode-gathering { background-color: #2e1065 !important; }
body.mode-family { background-color: #451a03 !important; }
body.mode-meeting { background-color: #0f172a !important; }
body.mode-class { background-color: #064e3b !important; }

