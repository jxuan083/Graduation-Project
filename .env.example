# Local development defaults. Copy to .env only when you need local overrides.

FIREBASE_PROJECT_ID=graduation-6ae65
GOOGLE_CLOUD_PROJECT=graduation-6ae65
FIREBASE_STORAGE_BUCKET=graduation-6ae65.firebasestorage.app

# Backend
BACKEND_PORT=8080
PORT=8080
ALLOWED_ORIGINS=http://localhost:5002,http://127.0.0.1:5002,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Firebase emulators. scripts/dev.sh exports these automatically as well.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
STORAGE_EMULATOR_HOST=http://127.0.0.1:9199

# Optional integrations. Core local flow must work when these are absent.
STT_ENGINE=openai-whisper
STT_MODEL=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_BATCH_SIZE=8
HUGGINGFACE_TOKEN=
OPENAI_API_KEY=
