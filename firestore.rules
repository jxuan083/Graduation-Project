rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== users =====
    // 任何登入者都能讀其他人的基本資料 (未來想加好友/leaderboard 用)
    // 只有自己能寫自己的資料
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // ===== rooms =====
    // 為了避免前端直接亂改房間狀態，rooms 只允許「房主」與「成員」讀。
    // 寫入交給後端 (Cloud Run 用 Admin SDK，會繞過這條規則)。
    match /rooms/{roomId} {
      allow read: if request.auth != null && (
        resource.data.host_uid == request.auth.uid ||
        request.auth.uid in resource.data.members
      );
      allow write: if false;     // 全部走後端 API，不允許 client 直接寫
    }

    // ===== meetings (聚會紀錄) =====
    // 只有當時參與這場聚會的人（在 participants 陣列裡）才能讀
    // 寫入完全交給後端
    match /meetings/{meetingId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow write: if false;
    }
  }
}
