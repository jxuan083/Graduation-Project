rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== users =====
    // 🔒 [C2 修正 v15.2] 收緊讀取規則:只能讀自己的完整 doc
    // 別人的 nickname/photoURL/bio 等公開欄位走後端 /api/users/{uid}/public
    // (後端 Admin SDK 會繞過這條規則,且只回傳公開欄位 — 不含 email)
    // 修正前: allow read: if request.auth != null  → 任何登入者可讀任何人的 email
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      // ===== 個人題庫 =====
      // 每個使用者有自己的私人題庫，只有自己能讀寫
      // 寫入也可以透過後端 Admin SDK（繞過規則）
      match /questions/{questionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ===== 好友名單 =====
      // 只有自己能讀自己的好友；寫入走後端 Admin SDK（才能同時維護雙邊）
      match /friends/{friendUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // ===== 好友邀請（收件/寄件） =====
      // 只有自己能讀；寫入走後端
      match /friend_requests/{requestId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // ===== 個人聚會紀錄鏡像（用於排行榜 query） =====
      // 只有自己能讀；寫入走後端
      match /meetings/{meetingId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ===== 公共題庫 =====
    // 所有登入者可讀；寫入只能由後端 Admin SDK 處理（seed / 管理）
    match /public_questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ===== rooms =====
    // 為了避免前端直接亂改房間狀態，rooms 只允許「房主」與「成員」讀。
    // 寫入交給後端 (Cloud Run 用 Admin SDK，會繞過這條規則)。
    match /rooms/{roomId} {
      allow read: if request.auth != null && (
        resource.data.host_uid == request.auth.uid ||
        request.auth.uid in resource.data.members
      );
      allow write: if false;     // 全部走後端 API，不允許 client 直接寫
    }

    // ===== meetings (聚會紀錄) =====
    // 只有當時參與這場聚會的人（在 participants 陣列裡）才能讀
    // 寫入完全交給後端
    match /meetings/{meetingId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow write: if false;

      // ===== 聚會照片 metadata =====
      // 讀：當時的參與者；寫：後端 Admin SDK
      match /photos/{photoId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/meetings/$(meetingId)).data.participants;
        allow write: if false;
      }
    }
  }
}
