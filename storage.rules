rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 頭像：每個 user 只能在自己的資料夾下寫，所有人可讀
    // 路徑慣例：avatars/{uid}/<filename>
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024              // 5 MB 上限
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // 個人寵物圖：前端會上傳到 pet-images/{uid}/pet.jpg。
    match /pet-images/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // 群組聊天室媒體（圖片 / 語音）：只有該群組成員能上傳到自己的資料夾。
    // 讀取靠帶 token 的下載 URL（同頭像模式），URL 只會出現在群組訊息裡。
    // 路徑慣例：group-chat/{groupId}/{uid}/<filename>
    match /group-chat/{groupId}/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && firestore.get(/databases/(default)/documents/groups/$(groupId)).data.member_uids.hasAny([request.auth.uid])
                   && (
                        (request.resource.contentType.matches('image/(jpeg|png|webp)')
                         && request.resource.size < 5 * 1024 * 1024)          // 圖片 5 MB
                     || (request.resource.contentType.matches('audio/.*')
                         && request.resource.size < 2 * 1024 * 1024)          // 語音 2 MB
                   );
    }

    // 聚會照片：client 讀寫一律拒絕；參與者經過後端身分檢查後取得內容。
    // 寫入也完全走後端 (Admin SDK 會繞過規則)
    // 路徑慣例：meeting-photos/{meetingId}/{photoId}.jpg
    match /meeting-photos/{meetingId}/{fileName} {
      // 不讓 client 繞過後端的參與者檢查直接枚舉讀取。
      allow read: if false;
      allow write: if false;
    }

    // 預設拒絕其他路徑
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
