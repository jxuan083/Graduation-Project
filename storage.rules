rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 頭像：每個 user 只能在自己的資料夾下寫，所有人可讀
    // 路徑慣例：avatars/{uid}/<filename>
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024              // 5 MB 上限
                   && request.resource.contentType.matches('image/.*');     // 必須是圖片
    }

    // 聚會照片：讀取開放給所有登入者（實際權限由後端 + download URL 控制）
    // 寫入完全走後端 (Admin SDK 會繞過規則)
    // 路徑慣例：meeting-photos/{meetingId}/{photoId}.jpg
    match /meeting-photos/{meetingId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 預設拒絕其他路徑
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
